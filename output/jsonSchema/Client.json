{
    "type": "object",
    "x-documentConfig": {
        "documentName": "Client",
        "dataIsolation": {
            "field": "userId"
        },
        "restApi": {
            "methods": [
                "get",
                "post",
                "patch"
            ],
            "joinWhitelist": [
                "area",
                "job",
                "jobReview"
            ]
        }
    },
    "properties": {
        "_id": {
            "type": "string",
            "x-format": "PrimaryUUID"
        },
        "userId": {
            "type": "string",
            "index": true,
            "x-foreignKey": {
                "schemaName": "User",
                "fieldName": "_id",
                "relationType": "one-to-one"
            }
        },
        "displayName": {
            "type": "string",
            "maxLength": 64,
            "required": true
        },
        "clientType": {
            "type": "string",
            "enum": [
                "individual",
                "business"
            ]
        },
        "phone": {
            "type": "number",
            "maxLength": 15
        },
        "active": {
            "type": "boolean",
            "default": true,
            "required": true
        },
        "createdBy": {
            "type": "string",
            "x-format": "UUID",
            "x-vexData": "userId"
        },
        "createdAt": {
            "type": "integer",
            "x-format": "UnixTimestamp",
            "x-vexData": "unixTimestampOnCreate"
        },
        "updatedBy": {
            "type": "string",
            "x-format": "UUID",
            "x-vexData": "userId"
        },
        "updatedAt": {
            "type": "integer",
            "x-format": "UnixTimestamp",
            "x-vexData": "unixTimestampOnUpdate"
        }
    },
    "required": [
        "displayName",
        "active"
    ]
}