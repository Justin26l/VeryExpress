{
    "main": "index.js",
    "scripts": {
        "build": "npm run openapi && tsc -p . && node scripts/build.js",
        "start": "node dist/server.js",
        "dev": "npm run openapi && nodemon --watch src --ext ts --exec ts-node src/server.ts",
        "openapi": "tsoa spec-and-routes",
        "docker-build": "docker build -t very-express .",
        "docker-start": "docker run -p 3000:3000 very-express"
    },
    "dependencies": {
        "cookie": "^0.6.0",
        "cookie-parser": "^1.4.6",
        "dotenv": "^16.4.4",
        "express": "^4.18.2",
        "helmet": "^7.1.0",
        "js-yaml": "^4.1.0",
        "jsonwebtoken": "^9.0.2",
        "passport": "^0.7.0",
        "passport-github": "^1.1.0",
        "passport-google-oauth20": "^2.0.0",
        "passport-jwt": "^4.0.1",
        "pg": "^8.20.0",
        "reflect-metadata": "^0.2.2",
        "swagger-ui-express": "^5.0.0",
        "tsoa": "^7.0.0-alpha.0",
        "typeorm": "^0.3.20"
    },
    "devDependencies": {
        "@types/cookie-parser": "^1.4.7",
        "@types/crypto-js": "^4.1.2",
        "@types/dotenv": "^8.2.0",
        "@types/express": "^4.17.17",
        "@types/js-yaml": "^4.0.9",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/mongodb": "^4.0.7",
        "@types/ms": "^2.1.0",
        "@types/node": "^20.4.2",
        "@types/passport": "^1.0.16",
        "@types/passport-github": "^1.1.12",
        "@types/passport-google-oauth20": "^2.0.14",
        "@types/pg": "^8.11.0",
        "@types/swagger-ui-express": "^4.1.6",
        "@types/ws": "^8.5.5",
        "nodemon": "^2.0.22",
        "strip-json-comments": "^5.0.1",
        "ts-node": "^10.9.1",
        "typescript": "^5.1.6"
    }
